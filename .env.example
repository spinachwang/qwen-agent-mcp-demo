# MiniMax (OpenAI-compatible) credentials
# Docs: https://platform.minimaxi.com/docs/guides/quickstart-sdk
MINIMAX_API_KEY=sk-your-key-here
MINIMAX_MODEL=MiniMax-M3

# Base URL must end with /v1 (qwen-agent appends /chat/completions)
# Adjust the host portion if your platform differs.
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
